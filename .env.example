# Port (default 3000)
PORT=3000

# Session encryption secret (auto-generated on first run if empty)
SESSION_SECRET=

# Trust reverse proxy headers (true if behind nginx/caddy)
TRUST_PROXY=false

# Working directory for Claude Code
WORKDIR=./workspace

# Max parallel Claude Code processes for Kanban tasks (default 5)
MAX_TASK_WORKERS=5

# Claude subprocess global timeout in milliseconds (default 30 minutes)
# Increase for long agentic tasks; decrease to fail-fast on hangs
CLAUDE_TIMEOUT_MS=1800000

# Claude execution mode: CLI or SDK
# - CLI: Uses @anthropic-ai/claude-code CLI (requires Claude Pro/Max subscription)
# - SDK: Uses @anthropic-ai/claude-agent-sdk (requires ANTHROPIC_API_KEY, supports GitHub Copilot)
# Default: CLI
CLAUDE_MODE=CLI

# Anthropic API Key (required when CLAUDE_MODE=SDK)
# Get your key from: https://console.anthropic.com/settings/keys
# GitHub Copilot subscribers can use this mode with their API access
ANTHROPIC_API_KEY=
